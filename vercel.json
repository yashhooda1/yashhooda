{
  "version": 2,
  "functions": {
    "api/chat.js": { "maxDuration": 60 },
    "api/analytics.js": { "maxDuration": 60 }
  },
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain"
        }
      ]
    }
  ]
}
