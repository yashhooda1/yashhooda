{
  "version": 2,
  "functions": {
    "api/chat.js":           { "maxDuration": 60, "memory": 1024 },
    "api/chat-search.js":    { "maxDuration": 60 },
    "api/analytics.js":      { "maxDuration": 90 },
    "api/tts.js":            { "maxDuration": 120 },
    "api/strava.js":         { "maxDuration": 30 },
    "api/history.js":        { "maxDuration": 30 },
    "api/flights.js":        { "maxDuration": 30 },
    "api/network.js":        { "maxDuration": 15 },
    "api/sports.js":         { "maxDuration": 15 },
    "api/imagine.js":        { "maxDuration": 60 },
    "api/runway.js":         { "maxDuration": 120 },
    "api/agent-learn.js":    { "maxDuration": 90 },
    "api/agent-research.js": { "maxDuration": 90 },
    "api/agent-log.js":      { "maxDuration": 90 },
    "api/agent-actions.js":   { "maxDuration": 30 },
    "api/analyze.js": {
      "maxDuration": 60,
      "memory": 1024
    },
    "api/code-agent.js": {
      "maxDuration": 120, "memory": 1024
    }
  },
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/agent-learn?secret=hooda-cron-2026",
      "schedule": "0 6 * * *"
    }
  ]
}
